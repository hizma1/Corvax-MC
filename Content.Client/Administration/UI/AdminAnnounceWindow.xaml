<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc admin-announce-title}"
    MinWidth="650"
    MinHeight="350">
    <BoxContainer Orientation="Vertical" Margin="4">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0,0,0,4">
            <LineEdit Name="Announcer" Access="Public" PlaceHolder="{Loc admin-announce-announcer-placeholder}" Text="{Loc admin-announce-announcer-default}" HorizontalExpand="True" />
            <LineEdit Name="Sender" Access="Public" PlaceHolder="{Loc admin-announce-sender-placeholder}" Text="{Loc admin-announce-sender-default}" HorizontalExpand="True" Margin="4,0,0,0" />
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0,0,0,4">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SizeFlagsStretchRatio="1.5">
                <Button Name="ColorPreview" Access="Public" Text=" " HorizontalExpand="False" MinSize="30, 30" Margin="0,0,4,0" />
                <LineEdit Name="ColorHex" Access="Public" PlaceHolder="{Loc admin-announce-color-placeholder}" Text="1d8bad" HorizontalExpand="True" />
            </BoxContainer>
            <LineEdit Name="SoundPath" Access="Public" PlaceHolder="{Loc admin-announce-sound-placeholder}" HorizontalExpand="True" SizeFlagsStretchRatio="3.5" Margin="4,0,0,0" />
        </BoxContainer>
        <TextEdit Name="Announcement" Access="Public" VerticalExpand="True" MinHeight="150" Margin="0,0,0,4" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0,4,0,0">
            <CheckBox Name="KeepWindowOpen" Access="Public" Text="{Loc admin-announce-keep-open}" VerticalAlignment="Center" />
            <Control HorizontalExpand="True" /> 
            <BoxContainer Orientation="Horizontal" MinWidth="300">
                <Button Name="AnnounceButton" Access="Public" Disabled="True" Text="{Loc admin-announce-button}" HorizontalExpand="True" />
                <OptionButton Name="AnnounceMethod" Access="Public" HorizontalExpand="True" Margin="4,0,0,0"/>
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Orientation="Vertical" Margin="0,8,0,0">
            <PanelContainer StyleClasses="LowDivider" />
            <Label Text="{Loc admin-announce-footer}" StyleClasses="WindowFooterText" Margin="0,2,0,0" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
