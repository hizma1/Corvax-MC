<BoxContainer xmlns="https://spacestation14.io"
              Orientation="Vertical"
              Margin="5 5 5 5">
    <PanelContainer StyleClasses="GuidebookEmbedCard">
        <BoxContainer Orientation="Vertical">
        <PanelContainer Name="NameBackground" HorizontalExpand="True" VerticalExpand="False">
            <RichTextLabel Name="ReagentName" HorizontalAlignment="Center"/>
        </PanelContainer>
        <BoxContainer Name="RecipesContainer" HorizontalExpand="True">
            <Collapsible HorizontalExpand="True">
                <CollapsibleHeading Title="{Loc 'guidebook-reagent-recipes-header'}" StyleClasses="GuidebookEmbedSectionHeading"/>
                <CollapsibleBody StyleClasses="GuidebookEmbedSectionBody">
                    <GridContainer Name="RecipesDescriptionContainer"
                                  Margin="10 0 10 0"
                                  Columns="1"
                                  HSeparationOverride="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalExpand="True"/>
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <BoxContainer Name="SourcesContainer" HorizontalExpand="True">
            <Collapsible HorizontalExpand="True">
                <CollapsibleHeading Title="{Loc 'guidebook-reagent-sources-header'}" StyleClasses="GuidebookEmbedSectionHeading"/>
                <CollapsibleBody StyleClasses="GuidebookEmbedSectionBody">
                    <GridContainer Name="SourcesDescriptionContainer"
                                   Margin="10 0 10 0"
                                   Columns="1"
                                   HSeparationOverride="5"
                                   HorizontalAlignment="Stretch"
                                   HorizontalExpand="True"/>
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <BoxContainer Name="EffectsContainer" HorizontalExpand="True">
            <Collapsible>
                <CollapsibleHeading Title="{Loc 'guidebook-reagent-effects-header'}" StyleClasses="GuidebookEmbedSectionHeading"/>
                <CollapsibleBody StyleClasses="GuidebookEmbedSectionBody">
                    <BoxContainer Name="EffectsDescriptionContainer"
                                  Orientation="Vertical"
                                  Margin="10 0 10 0"
                                  HorizontalExpand="True"/>
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <BoxContainer Name="PlantMetabolismsContainer" HorizontalExpand="True">
            <Collapsible>
                <CollapsibleHeading Title="{Loc 'guidebook-reagent-plant-metabolisms-header'}" StyleClasses="GuidebookEmbedSectionHeading"/>
                <CollapsibleBody StyleClasses="GuidebookEmbedSectionBody">
                    <BoxContainer Name="PlantMetabolismsDescriptionContainer"
                                  Orientation="Vertical"
                                  Margin="10 0 10 0"
                                  HorizontalExpand="True"/>
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <!-- <RMC14> -->
        <BoxContainer Name="FlammabilityContainer" HorizontalExpand="True">
            <Collapsible>
                <CollapsibleHeading Title="{Loc 'rmc-flamer-guidebook-header'}" StyleClasses="GuidebookEmbedSectionHeading"/>
                <CollapsibleBody StyleClasses="GuidebookEmbedSectionBody">
                    <BoxContainer Name="FlammabilityDescriptionContainer"
                                  Orientation="Vertical"
                                  Margin="10 0 10 0"
                                  HorizontalExpand="True"/>
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <!-- </RMC14> -->
        <BoxContainer Margin="10 5 10 10" HorizontalExpand="True">
            <!-- The troublemaker !-->
            <RichTextLabel Name="ReagentDescription" HorizontalAlignment="Left"/>
        </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</BoxContainer>
