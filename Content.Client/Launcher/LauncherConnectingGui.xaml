<!-- CM14 rework: non-RMC edit marker. -->
<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:parallax="clr-namespace:Content.Client.Parallax"
         xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls">
    <parallax:ParallaxControl SpeedX="20"/>
    <Control HorizontalAlignment="Center" VerticalAlignment="Center">
        <PanelContainer Name="FramePanel" StyleClasses="AngleRect LauncherConnectingFrame">
            <!-- CCM launcher connecting layout rework start -->
            <BoxContainer Orientation="Vertical" MinSize="520 180">
                <BoxContainer Orientation="Horizontal" Margin="6 4 6 0">
                    <Label Margin="8 0 0 0" Text="{Loc 'connecting-title'}"
                           StyleClasses="LauncherConnectingTitle" VAlign="Center" />
                    <Button Name="ExitButton" Text="{Loc 'connecting-exit'}"
                            HorizontalAlignment="Right" HorizontalExpand="True" StyleClasses="LauncherConnectingButton" />
                </BoxContainer>
                <PanelContainer Name="HeaderDivider" StyleClasses="LauncherConnectingDivider" />
                <BoxContainer Orientation="Vertical" VerticalExpand="True" Margin="10 10 10 2" SeparationOverride="8">
                    <Control VerticalExpand="True" Margin="0 0 0 8">
                        <BoxContainer Orientation="Vertical" Name="ConnectingStatus">
                            <Label Text="{Loc 'connecting-in-progress'}" Align="Center" StyleClasses="LauncherConnectingStateLabel" />
                            <Label Name="ConnectStatus" StyleClasses="LauncherConnectingStateLabel" Align="Center" />
                        </BoxContainer>
                        <BoxContainer Orientation="Vertical" Name="ConnectFail" Visible="False" SeparationOverride="10">
                            <PanelContainer Name="ConnectFailCard">
                                <BoxContainer Orientation="Vertical" Margin="12 10 12 10" SeparationOverride="6">
                                    <Label Name="ConnectFailHeader" StyleClasses="LauncherConnectingTitle" />
                                    <RichTextLabel Name="ConnectFailReason" VerticalAlignment="Stretch" StyleClasses="LauncherConnectingReasonSmallLabel"/>
                                </BoxContainer>
                            </PanelContainer>
                            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                                <Button Name="RetryButton"
                                        Text="{Loc 'connecting-retry'}"
                                        TextAlign="Center"
                                        HorizontalExpand="True"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        StyleClasses="LauncherConnectingButton"/>
                                <Button Name="CopyButton"
                                        Text="{Loc 'connecting-copy'}"
                                        TextAlign="Center"
                                        HorizontalExpand="True"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        StyleClasses="LauncherConnectingButton"/>
                            </BoxContainer>
                        </BoxContainer>
                        <BoxContainer Orientation="Vertical" Name="Disconnected" Visible="False" SeparationOverride="10">
                            <PanelContainer Name="DisconnectedCard">
                                <BoxContainer Orientation="Vertical" Margin="12 10 12 10" SeparationOverride="6">
                                    <Label Name="DisconnectedHeader" Text="{Loc 'connecting-disconnected'}" Align="Left" StyleClasses="LauncherConnectingTitle" />
                                    <Label Name="DisconnectReason" Align="Left" StyleClasses="LauncherConnectingReasonSmallLabel" />
                                </BoxContainer>
                            </PanelContainer>
                            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalAlignment="Bottom">
                                <Button Name="ReconnectButton"
                                        Text="{Loc 'connecting-reconnect'}"
                                        TextAlign="Center"
                                        HorizontalExpand="True"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        StyleClasses="LauncherConnectingButton"/>
                                <Button Name="CopyButtonDisconnected"
                                        Text="{Loc 'connecting-copy'}"
                                        TextAlign="Center"
                                        HorizontalExpand="True"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        StyleClasses="LauncherConnectingButton"/>
                            </BoxContainer>
                        </BoxContainer>
                    </Control>
                    <PanelContainer Name="AddressCard">
                        <Label Name="ConnectingAddress" StyleClasses="LauncherConnectingStateLabel" HorizontalAlignment="Center" Margin="8 6 8 6" />
                    </PanelContainer>
                </BoxContainer>
            </BoxContainer>
            <!-- CCM launcher connecting layout rework end -->
        </PanelContainer>
    </Control>
</Control>
