<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
         xmlns:style="clr-namespace:Content.Client.Stylesheets"
         VerticalExpand="True">
    <Control>
        <PanelContainer Name="BackgroundPanel" />
        <PanelContainer Name="MenuBorderPanel" MouseFilter="Ignore" />
        <BoxContainer Name="NewLayoutRoot" Orientation="Vertical" SeparationOverride="8" Margin="8 8 8 8" VerticalExpand="True">
            <PanelContainer Name="WindowHeader">
                <BoxContainer Orientation="Horizontal">
                    <PanelContainer HorizontalExpand="True">
                        <Label Name="TitleLabel" Margin="5 0 0 0" HorizontalExpand="True"
                               Text="{Loc 'character-setup-gui-title'}"
                               VAlign="Center" StyleClasses="windowTitle" />
                    </PanelContainer>
                    <TextureButton Name="CloseButton" StyleClasses="CharacterSetupVisibleCloseButton" VerticalAlignment="Center" MinSize="22 22" />
                </BoxContainer>
            </PanelContainer>
            <ScrollContainer Name="BodyScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                <BoxContainer Name="BodyStack" Orientation="Vertical" SeparationOverride="8" VerticalExpand="True">
                    <PanelContainer Name="CarouselPanel" MinHeight="200" HorizontalExpand="True">
                        <LayoutContainer Name="CarouselLayout" HorizontalExpand="True" VerticalExpand="True">
                            <PanelContainer Name="CarouselBackgroundPanel" HorizontalExpand="True" VerticalExpand="True" MouseFilter="Ignore" />
                            <PanelContainer Name="CarouselBorderPanel" HorizontalExpand="True" VerticalExpand="True" MouseFilter="Ignore" />
                            <BoxContainer Name="CarouselSideShade"
                                          Orientation="Horizontal"
                                          HorizontalExpand="True"
                                          VerticalExpand="True"
                                          MouseFilter="Ignore">
                                <PanelContainer Name="CarouselLeftShade" MinWidth="140" />
                                <Control HorizontalExpand="True" />
                                <PanelContainer Name="CarouselRightShade" MinWidth="140" />
                            </BoxContainer>
                        </LayoutContainer>
                        <BoxContainer Name="CarouselPreviewRow" Orientation="Horizontal" SeparationOverride="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12">
                        <PanelContainer Name="LeftFarPreviewContainer" MinSize="160 140">
                            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="6">
                                <SpriteView Name="LeftFarPreview" Scale="5.1 5.1" SetSize="112 112" OverrideDirection="South" />
                                <Label Name="LeftFarNameLabel" HorizontalAlignment="Center" StyleClasses="CharacterCarouselName" />
                            </BoxContainer>
                        </PanelContainer>
                        <PanelContainer Name="LeftPreviewContainer" MinSize="180 160">
                            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="6">
                                <SpriteView Name="LeftPreview" Scale="6.4 6.4" SetSize="128 128" OverrideDirection="South" />
                                <Label Name="LeftNameLabel" HorizontalAlignment="Center" StyleClasses="CharacterCarouselName" />
                            </BoxContainer>
                        </PanelContainer>
                            <PanelContainer Name="CenterPreviewContainer" MinSize="220 180">
                                <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="6">
                                <SpriteView Name="CenterPreview" Scale="7 7" SetSize="140 140" OverrideDirection="South" />
                                <Label Name="CenterNameLabel" HorizontalAlignment="Center" StyleClasses="CharacterCarouselName CharacterCarouselNameSelected" />
                            </BoxContainer>
                        </PanelContainer>
                        <PanelContainer Name="RightPreviewContainer" MinSize="180 160">
                            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="6">
                                <SpriteView Name="RightPreview" Scale="6.4 6.4" SetSize="128 128" OverrideDirection="South" />
                                <Label Name="RightNameLabel" HorizontalAlignment="Center" StyleClasses="CharacterCarouselName" />
                            </BoxContainer>
                        </PanelContainer>
                        <PanelContainer Name="RightFarPreviewContainer" MinSize="160 140">
                            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="6">
                                <SpriteView Name="RightFarPreview" Scale="5.1 5.1" SetSize="112 112" OverrideDirection="South" />
                                <Label Name="RightFarNameLabel" HorizontalAlignment="Center" StyleClasses="CharacterCarouselName" />
                            </BoxContainer>
                        </PanelContainer>
                        </BoxContainer>
                    </PanelContainer>
                    <BoxContainer Name="ActionButtonRow"
                                  Orientation="Horizontal"
                                  HorizontalExpand="True"
                                  MinHeight="40">
                        <Control Name="TransferActionButtonSpacer" />
                        <Control HorizontalExpand="True" />
                        <BoxContainer Name="PrimaryActionButtonGroup"
                                      Orientation="Horizontal"
                                      SeparationOverride="10"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <Button Name="NewCharacterButton" Text="{Loc 'character-setup-gui-new-character'}" StyleClasses="CharacterSetupActionButton" />
                            <Button Name="SaveCharacterButton" Text="{Loc 'character-setup-gui-save-character'}" StyleClasses="CharacterSetupActionButton" />
                            <Button Name="ResetCharacterButton" Text="{Loc 'character-setup-gui-reset-character'}" StyleClasses="CharacterSetupActionButton" />
                            <Button Name="DeleteCharacterButton" Text="{Loc 'character-setup-gui-delete-character'}" StyleClasses="CharacterSetupActionButton" />
                        </BoxContainer>
                        <Control HorizontalExpand="True" />
                        <BoxContainer Name="TransferActionButtonGroup"
                                      Orientation="Horizontal"
                                      SeparationOverride="10"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center">
                            <Button Name="ImportCharacterButton" Text="{Loc 'humanoid-profile-editor-import-button'}" StyleClasses="CharacterSetupActionButton" />
                            <Button Name="ExportCharacterButton" Text="{Loc 'humanoid-profile-editor-export-button'}" StyleClasses="CharacterSetupActionButton" />
                        </BoxContainer>
                    </BoxContainer>
                    <PanelContainer Name="EditorTopDivider">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="{x:Static style:StyleNano.NanoGold}" ContentMarginTopOverride="2" />
                        </PanelContainer.PanelOverride>
                    </PanelContainer>
                    <BoxContainer Name="CharEditor" HorizontalExpand="True" VerticalExpand="True" />
                </BoxContainer>
            </ScrollContainer>
        </BoxContainer>
        <BoxContainer Name="OldLayoutRoot" Visible="False" Orientation="Vertical" SeparationOverride="0"
                      Margin="4 4 4 4" VerticalExpand="True" HorizontalExpand="True">
            <PanelContainer Name="OldWindowHeader" StyleClasses="OldLobbyAngleRect">
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" MinHeight="32" Margin="4 0 4 0" SeparationOverride="6">
                    <BoxContainer Name="OldTransferActionButtonGroup"
                                  Orientation="Horizontal"
                                  SeparationOverride="4"
                                  VerticalAlignment="Center">
                        <Button Name="OldImportCharacterButton" Text="{Loc 'humanoid-profile-editor-import-button'}" StyleClasses="OldLobbyButton" />
                        <Button Name="OldExportCharacterButton" Text="{Loc 'humanoid-profile-editor-export-button'}" StyleClasses="OldLobbyButton" />
                    </BoxContainer>
                    <Control HorizontalExpand="True" />
                    <Label Name="OldHeaderTitleLabel"
                           Margin="8 0 8 0"
                           VerticalAlignment="Center"
                           Text="{Loc 'character-setup-gui-character-setup-label'}"
                           VAlign="Center"
                           StyleClasses="OldLobbyTitle" />
                    <Control HorizontalExpand="True" />
                    <BoxContainer Name="OldPrimaryActionButtonCluster"
                                  Orientation="Horizontal"
                                  SeparationOverride="4"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right">
                        <BoxContainer Name="OldPrimaryActionButtonGroup"
                                      Orientation="Horizontal"
                                      SeparationOverride="4"
                                      VerticalAlignment="Center">
                            <Button Name="OldNewCharacterButton" Text="{Loc 'character-setup-gui-new-character'}" StyleClasses="OldLobbyButton" />
                            <Button Name="OldSaveCharacterButton" Text="{Loc 'character-setup-gui-save-character'}" StyleClasses="OldLobbyButton" />
                            <Button Name="OldResetCharacterButton" Text="{Loc 'character-setup-gui-reset-character'}" StyleClasses="OldLobbyButton" />
                            <Button Name="OldDeleteCharacterButton" Text="{Loc 'character-setup-gui-character-setup-stats-button'}" StyleClasses="OldLobbyButton" />
                        </BoxContainer>
                        <Button Name="OldCloseButton"
                                Access="Public"
                                Text="{Loc 'character-setup-gui-character-setup-close-button'}"
                                StyleClasses="OldLobbyButton"/>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
            <PanelContainer Name="OldEditorTopDivider">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="{x:Static style:StyleNano.NanoGold}" ContentMarginTopOverride="2" />
                </PanelContainer.PanelOverride>
            </PanelContainer>
            <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="0">
                <ScrollContainer Name="OldCharactersScroll" MinSize="325 0" Margin="5 5 0 0">
                    <BoxContainer Name="OldCharacters" Orientation="Vertical" />
                </ScrollContainer>
                <PanelContainer Name="OldVerticalDivider" MinSize="2 0">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="{x:Static style:StyleNano.NanoGold}" ContentMarginTopOverride="2" />
                    </PanelContainer.PanelOverride>
                </PanelContainer>
                <BoxContainer Name="OldEditorHost" HorizontalExpand="True" VerticalExpand="True" Margin="6 5 0 0" />
            </BoxContainer>
        </BoxContainer>
    </Control>
</Control>
