<lobbyUi:LobbyOldLayout xmlns="https://spacestation14.io"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                        xmlns:info="clr-namespace:Content.Client.Info"
                        xmlns:lobbyUi="clr-namespace:Content.Client.Lobby.UI"
                        xmlns:style="clr-namespace:Content.Client.Stylesheets"
                        xmlns:widgets="clr-namespace:Content.Client.UserInterface.Systems.Chat.Widgets"
                        VerticalExpand="True"
                        HorizontalExpand="True">
    <TextureRect Name="Background" Access="Public" VerticalExpand="True" HorizontalExpand="True"
                 Stretch="KeepAspectCovered" />
    <BoxContainer Name="MainContainer" VerticalExpand="True" HorizontalExpand="True" Orientation="Horizontal"
                  Margin="10 10 10 10" SeparationOverride="2">
        <SplitContainer State="Auto" ResizeMode="NotResizable" HorizontalExpand="True">
            <BoxContainer Name="LeftSide" Access="Public" Orientation="Vertical" SeparationOverride="4" HorizontalExpand="True">
                <Control Name="DefaultState" Access="Public" VerticalExpand="True">
                    <BoxContainer Name="TopLeft" Orientation="Vertical" HorizontalExpand="True">
                        <PanelContainer Name="LeftSideHeader" Access="Public" StyleClasses="OldLobbyAngleRect" HorizontalAlignment="Left"
                                        MinWidth="760"
                                        MaxWidth="840"
                                        HorizontalExpand="True"
                                        VerticalAlignment="Top">
                            <BoxContainer Orientation="Horizontal" SeparationOverride="6" Margin="6 6 6 6"
                                          HorizontalExpand="True" MaxWidth="840">
                                <Button Name="DiscordInfoButton" Access="Public"
                                        Text="{Loc 'server-info-discord-button'}"
                                        StyleClasses="OldLobbyButton"
                                        HorizontalExpand="True" />
                                <Button Name="WikiButton" Access="Public"
                                        Text="{Loc 'server-info-wiki-button'}"
                                        StyleClasses="OldLobbyButton"
                                        HorizontalExpand="True" />
                                <Button Name="GuidesButton" Access="Public"
                                        Text="{Loc 'ui-lobby-guides-button'}"
                                        StyleClasses="OldLobbyButton"
                                        HorizontalExpand="True" />
                                <Button Name="UpdatesButton" Access="Public"
                                        Text="{Loc 'ui-lobby-updates-button'}"
                                        StyleClasses="OldLobbyButtonRed"
                                        HorizontalExpand="True" />
                                <Button Name="AchievementsButton" Access="Public"
                                        Text="{Loc 'ui-lobby-taskbar-achievements'}"
                                        StyleClasses="OldLobbyButton"
                                        HorizontalExpand="True" />
                                <Button Name="StatsButton" Access="Public"
                                        Text="{Loc 'ui-lobby-taskbar-rating'}"
                                        StyleClasses="OldLobbyButton"
                                        HorizontalExpand="True" />
                            </BoxContainer>
                        </PanelContainer>
                        <PanelContainer StyleClasses="OldLobbyAngleRect" HorizontalAlignment="Left" Name="LeftSideTop" Access="Public"
                                        MinWidth="760"
                                        MaxWidth="840"
                                        HorizontalExpand="True"
                                        VerticalAlignment="Top">
                            <controls:StripeBack StyleClasses="OldLobbyStripeBack"
                                                 HasTopEdge="False"
                                                 HasBottomEdge="False"
                                                 HasMargins="False"
                                                 HorizontalExpand="True">
                                <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" MaxWidth="840"
                                              HorizontalExpand="True">
                                    <BoxContainer Orientation="Horizontal" SeparationOverride="10" Margin="6 5 6 5"
                                                  MinHeight="38" HorizontalExpand="True">
                                        <BoxContainer Orientation="Horizontal"
                                                      MinWidth="210"
                                                      MaxWidth="210"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center">
                                            <Button Name="ObserveButton" Access="Public"
                                                    Text="{Loc 'ui-lobby-observe-button'}"
                                                    StyleClasses="OldLobbyButton"
                                                    MinWidth="170"
                                                    MinHeight="30"
                                                    HorizontalAlignment="Left"
                                                    TextAlign="Center" />
                                        </BoxContainer>
                                        <BoxContainer Orientation="Horizontal"
                                                      HorizontalExpand="True"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center">
                                            <Label Name="StartTimeLabel" Access="Public"
                                                   StyleClasses="LabelHeadingBigger OldLobbyHeading OldLobbyCenteredText"
                                                   MinWidth="320"
                                                   MinHeight="30"
                                                   HorizontalExpand="True"
                                                   HorizontalAlignment="Center"
                                                   VAlign="Center" />
                                        </BoxContainer>
                                        <BoxContainer Orientation="Horizontal"
                                                      MinWidth="210"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      SeparationOverride="6">
                                            <Button Name="JoinHiveButton" Access="Public"
                                                    Text="{Loc 'ui-lobby-join-hive-button'}"
                                                    StyleClasses="OldLobbyButton" Visible="False" MinWidth="190"
                                                    MinHeight="30"
                                                    TextAlign="Center"
                                                    HorizontalAlignment="Right" />
                                            <Button Name="JoinUsmcButton" Access="Public"
                                                    Text="{Loc 'ui-lobby-join-uscm-button'}"
                                                    StyleClasses="OldLobbyButton" MinWidth="190" MinHeight="30"
                                                    TextAlign="Center"
                                                    HorizontalAlignment="Right"
                                                    Visible="False" />
                                            <Button Name="ReadyButton" Access="Public" ToggleMode="True"
                                                    Text="{Loc 'ui-lobby-ready-up-button'}"
                                                    StyleClasses="OldLobbyButton" MinWidth="170" MinHeight="30"
                                                    TextAlign="Center"
                                                    HorizontalAlignment="Right" />
                                        </BoxContainer>
                                    </BoxContainer>
                                </BoxContainer>
                            </controls:StripeBack>
                        </PanelContainer>
                        <BoxContainer Orientation="Vertical" SeparationOverride="4" Name="VoteContainer"
                                      Access="Public" HorizontalAlignment="Left"
                                      VerticalAlignment="Top" Margin="0 8" />
                    </BoxContainer>
                    <Control VerticalExpand="True" />
                    <BoxContainer Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <PanelContainer StyleClasses="OldLobbyAngleRect">
                            <BoxContainer Orientation="Vertical" Margin="5 5 5 5" SeparationOverride="3">
                                <Label Text="{Loc 'ui-lobby-music-header'}" StyleClasses="LabelBig OldLobbyHeading" />
                                <Label Name="LobbyMusicText" Access="Public" HorizontalAlignment="Left" StyleClasses="OldLobbyMutedText" />
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </Control>
            </BoxContainer>
            <PanelContainer Name="RightSide" Access="Public" StyleClasses="OldLobbyAngleRect"
                            HorizontalAlignment="Right" VerticalExpand="True"
                            VerticalAlignment="Stretch">
                <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="6" Margin="6 6 6 6">
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" MinSize="0 28">
                        <Label Name="ServerName" Access="Public"
                               StyleClasses="OldLobbyTitle"
                               HorizontalAlignment="Center"
                               HorizontalExpand="True"
                               VAlign="Center" />
                        <TextureButton Name="CollapseButton" Access="Public"
                                       TexturePath="filled_right_arrow.svg.192dpi"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0 2 2 0"
                                       ModulateSelfOverride="#DEDEDE"
                                       Scale="0.5 0.5" />
                    </BoxContainer>
                    <controls:HLine Color="{x:Static style:StyleNano.OldLobbyGold}" Thickness="2" />
                    <BoxContainer Orientation="Horizontal" MinSize="0 40" Name="TopButtonBar"
                                  SeparationOverride="4" HorizontalExpand="True" HorizontalAlignment="Stretch">
                        <Button Name="AHelpButton" Access="Public" Text="{Loc 'ui-lobby-ahelp-button'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                SizeFlagsStretchRatio="0.84" />
                        <Button Name="PollsButton" Access="Public" Text="{Loc 'ui-lobby-polls-button'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                SizeFlagsStretchRatio="1.18" />
                        <Button Name="OptionsButton" Access="Public" Text="{Loc 'ui-lobby-options-button'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                SizeFlagsStretchRatio="1.06" />
                        <Button Name="SponsorshipButton" Access="Public"
                                Text="{Loc 'ui-lobby-taskbar-donate'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                SizeFlagsStretchRatio="1.22" />
                        <Button Name="LeaveButton" Access="Public" Text="{Loc 'ui-lobby-leave-button'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                SizeFlagsStretchRatio="0.84" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                        <Button Name="LinkDiscordButton" Access="Public"
                                Text="{Loc 'ui-lobby-link-discord-button'}"
                                StyleClasses="OldLobbyButton"
                                HorizontalExpand="True"
                                HorizontalAlignment="Stretch" />
                    </BoxContainer>
                    <controls:HSpacer Spacing="4" />
                    <Label Text="{Loc 'ui-lobby-server-info-block'}"
                           StyleClasses="OldLobbyHeading" />
                    <info:ServerInfo Name="ServerInfo" Access="Public" MinSize="0 30"
                                     VerticalExpand="False" Margin="3 3 3 3"
                                     MaxWidth="420" HorizontalAlignment="Left" />
                    <Label Name="StationTime" Access="Public" Margin="3 0 3 0" HorizontalAlignment="Left" StyleClasses="OldLobbyMutedText" />
                    <Label Name="RoundStartTimer" Access="Public" Text="" Margin="3 0 3 0"
                           HorizontalAlignment="Left" StyleClasses="OldLobbyMutedText" />
                    <controls:HSpacer Spacing="4" />
                    <controls:HLine Color="{x:Static style:StyleNano.OldLobbyGold}" Thickness="2" />
                    <controls:HSpacer Spacing="4" />
                    <lobbyUi:LobbyCharacterPreviewPanel Name="CharacterPreview" Access="Public" />
                    <widgets:ChatBox Name="Chat" Access="Public" VerticalExpand="True" Margin="3 3 3 3" MinHeight="50" />
                </BoxContainer>
            </PanelContainer>
        </SplitContainer>
        <PanelContainer Name="ExpandPanel" Access="Public"
                        StyleClasses="OldLobbyAngleRect"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0 2 2 0"
                        Visible="False">
            <TextureButton Name="ExpandButton" Access="Public"
                           TexturePath="filled_left_arrow.svg.192dpi"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           ModulateSelfOverride="#DEDEDE"
                           Scale="0.5 0.5" />
        </PanelContainer>
    </BoxContainer>
    <LayoutContainer Access="Public"
                     Visible="False"
                     Name="CharacterSetupState"
                     VerticalExpand="True"
                     HorizontalExpand="True" />
</lobbyUi:LobbyOldLayout>
