<!-- CM14 rework: non-RMC edit marker. -->
<ccm:DefaultCMWindow xmlns="https://spacestation14.io"
                     xmlns:ccm="clr-namespace:Content.Client._CCM.UserInterface.Controls"
                     Title="{Loc 'ui-options-language-restart-title'}"
                     SetSize="460 160"
                     MinSize="460 160"
                     StyleClasses="OptionsMenuRoot"
                     Resizable="False">
    <BoxContainer Orientation="Vertical" SeparationOverride="10" Margin="10">
        <Label Name="MessageLabel"
               HorizontalExpand="True"
               VerticalExpand="True"
               ClipText="False"
               Text="{Loc 'ui-options-language-restart-warning'}" />
        <BoxContainer Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      SeparationOverride="8">
            <Button Name="ConfirmButton"
                    MinWidth="160"
                    Text="{Loc 'ui-options-language-restart-confirm'}" />
            <Button Name="CancelButton"
                    MinWidth="140"
                    Text="{Loc 'ui-options-language-restart-cancel'}" />
        </BoxContainer>
    </BoxContainer>
</ccm:DefaultCMWindow>
