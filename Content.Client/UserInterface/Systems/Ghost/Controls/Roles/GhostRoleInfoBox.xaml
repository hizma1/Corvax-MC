<BoxContainer xmlns="https://spacestation14.io"
              xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
              Orientation="Vertical"
              HorizontalExpand="True">
    <PanelContainer HorizontalExpand="True">
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat BackgroundColor="#0D151C" BorderColor="#1D303C" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      SeparationOverride="10"
                      Margin="8 6">
            <PanelContainer Name="PreviewFrame"
                            MinSize="64 64"
                            VerticalAlignment="Top">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#0B1117" BorderColor="#C49A54" BorderThickness="1" />
                </PanelContainer.PanelOverride>
            </PanelContainer>
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          SeparationOverride="4">
                <Label Name="Title"
                       StyleClasses="LabelBig"
                       ClipText="True"
                       HorizontalExpand="True" />
                <RichTextLabel Name="Description"
                               Margin="0 0 0 4"
                               HorizontalExpand="True" />
                <BoxContainer Name="ButtonHost"
                              Orientation="Vertical"
                              HorizontalExpand="True" />
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</BoxContainer>
