<controls:VehicleStatusWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._CCM.Vehicle.UI.Status"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    xmlns:stui="clr-namespace:Content.Client._CCM.UserInterface.Control"
    Title="{Loc ccm-ui-vehicle-status-title}"
    MinSize="520 700">
    <PanelContainer>
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat 
                BorderColor="#2A2A2A" 
                BorderThickness="2"
                BackgroundColor="#0F0F0F" />
        </PanelContainer.PanelOverride>
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="8">
                <PanelContainer HorizontalExpand="True" Margin="0 0 0 12">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat 
                            BorderColor="#4A4A4A" 
                            BorderThickness="1" 
                            BackgroundColor="#1A1A1A" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="8">
                        <Label Text="{Loc ccm-ui-vehicle-status-title}" 
                               StyleClasses="LabelHeading" 
                               FontColorOverride="#E0E0E0"
                               HorizontalAlignment="Center"
                               Margin="0 4"/>
                        <stui:CCMProgressBar Name="IntegrityProgressBar" Access="Public" 
                                   MinValue="0" MaxValue="100" 
                                   MinHeight="24"
                                   HorizontalExpand="True"
                                   Margin="4 8"/>
                    </BoxContainer>
                </PanelContainer>
                <PanelContainer Name="DoorLockPanel" Access="Public" 
                              HorizontalExpand="True" Margin="0 0 0 12">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat 
                            BorderColor="#3A3A3A" 
                            BorderThickness="1" 
                            BackgroundColor="#252525" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Horizontal" Margin="8" HorizontalExpand="True">
                        <Label Text="{Loc ccm-ui-vehicle-door-state-label}" 
                               StyleClasses="LabelSubText"
                               FontColorOverride="#B0B0B0"
                               VerticalAlignment="Center"/>
                        <Control HorizontalExpand="True"/>
                        <Label Name="DoorLockLabel" Access="Public" 
                               HorizontalAlignment="Right"/>
                    </BoxContainer>
                </PanelContainer>
                <PanelContainer HorizontalExpand="True" Margin="0 0 0 12">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat 
                            BorderColor="#3A3A3A" 
                            BorderThickness="1" 
                            BackgroundColor="#252525" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="6">
                        <Button Name="ResistancesToggle" Access="Public" 
                               StyleClasses="OpenBoth" 
                               HorizontalExpand="True" 
                               Margin="4"/>
                        <BoxContainer Name="ResistancesContainer" Access="Public" 
                                    Orientation="Vertical" Margin="6 4 4 4" 
                                    Visible="False"/>
                    </BoxContainer>
                </PanelContainer>
                <PanelContainer HorizontalExpand="True" Margin="0 0 0 12">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat 
                            BorderColor="#3A3A3A" 
                            BorderThickness="1" 
                            BackgroundColor="#252525" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="6">
                        <Button Name="PassengersToggle" Access="Public" 
                               StyleClasses="OpenBoth" 
                               HorizontalExpand="True" Margin="4"/>
                        <BoxContainer Name="PassengersContentContainer" Access="Public" 
                                    Orientation="Vertical" Margin="6 4 4 4" 
                                    Visible="False">
                            <BoxContainer Name="PassengerCategoriesContainer" Access="Public" 
                                        Orientation="Vertical"
                                        Margin="4 2"/>
                        </BoxContainer>
                    </BoxContainer>
                </PanelContainer>
                <ui:BlueHorizontalSeparator Margin="8 12"/>
                <PanelContainer HorizontalExpand="True">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat 
                            BorderColor="#3A3A3A" 
                            BorderThickness="1" 
                            BackgroundColor="#252525" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="8">
                        <Label Text="{Loc ccm-ui-vehicle-hardpoints}" 
                               StyleClasses="LabelHeading" 
                               FontColorOverride="Khaki" 
                               HorizontalAlignment="Center"
                               Margin="0 0 0 6"/>
                        <BoxContainer Name="HardpointsContainer" Access="Public" 
                                    Orientation="Vertical"
                                    Margin="4 0"/>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </ScrollContainer>
    </PanelContainer>
</controls:VehicleStatusWindow>
