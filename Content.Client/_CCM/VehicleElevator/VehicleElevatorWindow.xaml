<controls:VehicleElevatorWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._CCM.VehicleElevator"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    Title="{Loc ccm-vehicle-elevator-window-title}"
    MinSize="500 600">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Name="PlatformLabel" Access="Public" />
        <Button Name="LowerPlatformButton" Access="Public" Text="{Loc ccm-vehicle-elevator-button-lower}"
            StyleClasses="ButtonSquare" Visible="False" />
        <cc:HSeparator Color="#4972A1" Margin="0 5" />
        <ScrollContainer VerticalExpand="True">
            <BoxContainer Name="VehiclesContainer" Access="Public" Orientation="Vertical" />
        </ScrollContainer>
    </BoxContainer>
</controls:VehicleElevatorWindow>
