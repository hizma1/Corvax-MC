<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="Параметры защиты">
    <BoxContainer Orientation="Vertical" SeparationOverride="4" MinWidth="50" Margin="4">
        <Label Text="Защита от пуль" />
        <LineEdit Name="BulletLineEdit" PlaceHolder="Введите значение" />
        <Label Text="Защита в ближнем бою" />
        <LineEdit Name="MeleeLineEdit" PlaceHolder="Введите значение" />
        <Label Text="Защита от взрывов" />
        <LineEdit Name="ExplosionLineEdit" PlaceHolder="Введите значение" />
        <Label Text="Биозащита" />
        <LineEdit Name="BioLineEdit" PlaceHolder="Введите значение" />
    </BoxContainer>
</DefaultWindow>
