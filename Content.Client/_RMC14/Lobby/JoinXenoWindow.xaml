<controls:JoinXenoWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Lobby"
    Title="{Loc rmc-lobby-join-xeno}"
    MinSize="440 150">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <PanelContainer Name="StatusPanel" Access="Public">
            <BoxContainer Orientation="Vertical" Margin="10 10 10 10">
                <Label Name="Label" Access="Public" ClipText="False" />
            </BoxContainer>
        </PanelContainer>
        <PanelContainer Name="ButtonsPanel" Access="Public">
            <BoxContainer Name="Buttons" Access="Public" Orientation="Horizontal" Margin="10 10 10 10" SeparationOverride="8">
                <Button Name="LarvaButton" Access="Public" Text="{Loc rmc-lobby-join-as-larva}" HorizontalExpand="True" MinHeight="38" />
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:JoinXenoWindow>
