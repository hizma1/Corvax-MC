<controls:MarineControlComputerWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.ControlComputer"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    Title="Консоль управления Давидом" MinSize="350 350">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Text="[bold]Управление кораблем[/bold]" />
        <ui:BlueHorizontalSeparator />
        <Button Name="AlertButton" Access="Public" Text="{Loc rmc-alert-change-level}"
                StyleClasses="OpenBoth" />
        <Button Name="ShipAnnouncementButton" Access="Public" Text="Сделать объявление на весь корабль"
                StyleClasses="OpenBoth" />
        <Button Name="MedalButton" Access="Public" Text="Вручить медаль"
                StyleClasses="OpenBoth" />
        <RichTextLabel Text="[bold]Чрезвычайные меры[/bold]" Margin="0 20 0 0" />
        <ui:BlueHorizontalSeparator />
        <Button Name="EvacuationButton" Access="Public" HorizontalExpand="True"
                StyleClasses="OpenBoth" TextAlign="Left" />
    </BoxContainer>
</controls:MarineControlComputerWindow>
