<controls:EvacuationComputerWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.Evacuation"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    Title="Контроллер спасательной капсулы">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Text="[bold]Информационный дисплей[/bold]" />
        <ui:BlueHorizontalSeparator />
        <Label Name="StatusLabel" Access="Public" Text="Статус капсулы: ЭВАКУАЦИЯ НЕ ПРОВОДИТСЯ" />
        <Label Name="HatchLabel" Access="Public" Text="Стыковочный люк: НЕ ЗАКРЕПЛЕН" />
        <RichTextLabel Text="[bold]Управление капсулой[/bold]" Margin="0 10 0 0" />
        <ui:BlueHorizontalSeparator />
        <Button Name="DoorButton" Access="Public" Text="Разблокировать дверь" StyleClasses="OpenBoth" />
        <Button Name="EjectButton" Access="Public" Text="Ручной запуск" StyleClasses="OpenBoth" />
        <Button Name="DelayButton" Access="Public" Text="Задержать запуск" StyleClasses="OpenBoth" />
    </BoxContainer>
</controls:EvacuationComputerWindow>
