<controls:StaffHelpWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Mentor"
    Title="{Loc 'rmc-staff-help-window-title'}">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Text="{Loc 'rmc-staff-help-window-admin-description'}" />
        <Button Name="AdminHelpButton" Access="Public" Text="{Loc 'rmc-staff-help-window-admin-button'}" StyleClasses="OpenBoth" />
        <RichTextLabel Text="{Loc 'rmc-staff-help-window-mentor-description'}" Margin="0 20 0 0" />
        <Button Name="MentorHelpButton" Access="Public" Text="{Loc 'rmc-staff-help-window-mentor-button'}" StyleClasses="OpenBoth" />
    </BoxContainer>
</controls:StaffHelpWindow>
