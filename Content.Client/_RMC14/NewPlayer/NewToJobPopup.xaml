<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'rmc-new-to-job-popup-title'}"
                      SetSize="800 650">
    <BoxContainer Orientation="Vertical" Margin="20">
        <Label Name="TitleLabel"
               StyleClasses="LabelBig"
               HorizontalAlignment="Center"
               Margin="0 0 0 10" />
        <PanelContainer StyleClasses="BackgroundDark" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="10" VerticalExpand="True">
                <RichTextLabel Name="NewToJobName" HorizontalAlignment="Center" />
                <Control MinSize="0 5" />
                <ScrollContainer HScrollEnabled="False" VScrollEnabled="True" VerticalExpand="True" MinSize="0 250" Margin="20 5">
                    <RichTextLabel Name="NewToJobLabel" HorizontalAlignment="Left" />
                </ScrollContainer>
                <Control MinSize="0 5" />
                <RichTextLabel Name="NewToJobAdditional" HorizontalAlignment="Center" Margin="0 5 0 0" />
            </BoxContainer>
        </PanelContainer>
        <BoxContainer Orientation="Vertical" Margin="0 15 0 0">
            <Button Name="NewToJobCloseButton"
                    HorizontalAlignment="Center"
                    MinWidth="150" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
