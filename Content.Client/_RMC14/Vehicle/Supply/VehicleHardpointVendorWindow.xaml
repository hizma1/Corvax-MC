<controls:VehicleHardpointVendorWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Vehicle.Supply"
    MinSize="450 300">
    <BoxContainer Orientation="Vertical" SeparationOverride="4">
        <BoxContainer Orientation="Horizontal" SeparationOverride="6" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SizeFlagsStretchRatio="1" VerticalExpand="True">
                <Label Text="{Loc 'rmc-vehicle-vendor-vehicles'}" />
                <ItemList Name="VehicleList" Access="Public" VerticalExpand="True" />
            </BoxContainer>
            <BoxContainer Orientation="Vertical" SizeFlagsStretchRatio="1" VerticalExpand="True">
                <Label Text="{Loc 'rmc-vehicle-vendor-equipment'}" />
                <ItemList Name="HardpointList" Access="Public" VerticalExpand="True" />
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" SeparationOverride="6">
            <Button Name="PrintButton" Access="Public" Text="{Loc 'rmc-vehicle-vendor-print'}" />
        </BoxContainer>
    </BoxContainer>
</controls:VehicleHardpointVendorWindow>
