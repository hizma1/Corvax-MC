<cc:XenoChooseStructureWindow
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client._RMC14.Xenonids.Construction"
    Title="{Loc cm-xeno-choose-resin-structure}"
    MinSize="330 360"
    SetSize="360 400">
    <ScrollContainer HScrollEnabled="False" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Vertical" Margin="6" SeparationOverride="4">
            <PanelContainer Name="HeaderPanel" Access="Public" HorizontalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="6 5 6 6" SeparationOverride="2">
                    <Label Name="WindowTitleLabel" Access="Public"
                           Text="{Loc cm-xeno-choose-resin-structure}"
                           StyleClasses="LabelBig" HorizontalExpand="True" />
                    <Label Name="NodeCountLabel" Access="Public" Text="" Visible="False" />
                </BoxContainer>
            </PanelContainer>
            <PanelContainer Name="StructureListPanel" Access="Public" HorizontalExpand="True" VerticalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="4" SeparationOverride="3"
                              Name="StructureContainer" Access="Public" />
            </PanelContainer>
        </BoxContainer>
    </ScrollContainer>
</cc:XenoChooseStructureWindow>
