<ui:XenoChoiceControl
    xmlns="https://spacestation14.io"
    xmlns:ui="clr-namespace:Content.Client._RMC14.Xenonids.UI">
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
        <Button Name="Button" Access="Public"
                HorizontalExpand="True" VerticalExpand="False"
                StyleClasses="ButtonSquare" Margin="0 0 0 2" MinHeight="34">
            <BoxContainer Orientation="Horizontal" Margin="3 1" HorizontalExpand="True">
                <TextureRect Name="Texture" Access="Public"
                             HorizontalExpand="False" VerticalExpand="False"
                             Margin="2" MinSize="24 24"/>
                <Control MinWidth="5"/>
                <RichTextLabel
                    Name="NameLabel"
                    Access="Public"
                    HorizontalExpand="True"
                    VerticalAlignment="Center"/>
            </BoxContainer>
        </Button>
    </BoxContainer>
</ui:XenoChoiceControl>
