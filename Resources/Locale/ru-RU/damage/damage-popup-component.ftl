-damage-popup-component-type =
    { $setting ->
        [combined] Комбинированный
        [total] Суммарный
        [delta] Дельта
        [hit] Попадание
       *[other] Неизвестно
    }
damage-popup-component-switched = Цель установлена на тип: { -damage-popup-component-type(setting: $setting) }
