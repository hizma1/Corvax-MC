ent-RMCHeadCivilianTanBeret = Бежевый берет
    .desc = Красивый модный берет, пользующийся популярностью у руководителей.
ent-RMCHeadCivilianWhiteBeret = Белый берет
    .desc = { ent-RMCHeadCivilianTanBeret.desc }
ent-RMCHeadCivilianBlackBeret = Чёрные берет
    .desc = { ent-RMCHeadCivilianTanBeret.desc }
ent-RMCHeadCivilianBrownBeret = Коричневы берет
    .desc = { ent-RMCHeadCivilianTanBeret.desc }
