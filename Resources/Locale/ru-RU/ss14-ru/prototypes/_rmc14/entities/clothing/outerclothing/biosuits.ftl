ent-RMCBaseBioSuit = { ent-RMCBaseArmor }
    .desc = { ent-RMCBaseArmor.desc }
ent-RMCSuitBioGeneral = Биокостюм
    .desc = Костюм, защищающий от биологического заражения.
    .suffix = Generic, RMC
ent-RMCArmorFirefighter = Противопожарный костюм PT-LT
    .desc = 'ПайроТех ЛТ' - это современный, лёгкий противопожарный костюм, разработанный "Фуджин". Он обеспечивает защиту от огня и перегрева, а также обеспечивает определенную степень защиты от физических травм.
ent-RMCSuitFirefighter = firesuit
    .desc = A suit that protects against fire and heat.
ent-RMCArmorSPPFirefighter = Противопожарный плащ T-20
    .desc = Прочная огнестойкий плащ без излишеств, предназначенный для аварийно-спасательных бригад СССП. Создан на основе конструкции ПайроТех ЛТ, но с использованием более дешевых материалов отечественного производства, он обеспечивает базовую защиту от перегрева и попадания мусора за счет веса и комфорта.
ent-RMCSuitBioWeYa = Биокостюм VI-BS MK I
    .desc = 'Vitezstvi - bio-Suit Mark II' - Соврменный и лёгкий био-костюм, разработанный подразделением патентного поиска и разработки Vitezstvi для деятельности в условиях, непригодных для жизни.
    .suffix = Generic, WeYa
