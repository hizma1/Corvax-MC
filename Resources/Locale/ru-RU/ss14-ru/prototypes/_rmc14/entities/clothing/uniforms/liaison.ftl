ent-CMJumpsuitLiaisonBlue = синие костюмные брюки
    .desc = Синие слаксы в сочетании с белой рубашкой. Частая пара среди корпоративных служащих.
ent-CMJumpsuitLiaisonBlueKutjevoGoon = { ent-CMJumpsuitLiaisonBlue }
