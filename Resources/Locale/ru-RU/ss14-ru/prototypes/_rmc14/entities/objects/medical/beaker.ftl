ent-CMBeakerBase = { ent-BaseBeaker }
    .desc = { ent-BaseBeaker.desc }
ent-RMCBeakerBaseMetallic = { ent-BaseBeakerMetallic }
    .desc = { ent-BaseBeakerMetallic.desc }
ent-CMBeaker = мензурка
    .desc = Мензурка. Вмещает до 60 единиц.
ent-CMBeakerLarge = большая мензурка
    .desc = Большая мензурка. Вмещает до 120 единиц.
ent-RMCBeakerHighCapacity = мензурка большой ёмкости
    .desc = Мензурка с увеличенной ёмкостью, изготовленная из синего тонированного плексигласа, чтобы выдерживать большее давление. Вмещает до 300 единиц.
ent-CMMiniTank = смарт-баллон для пополнения MS-11
    .desc = Маленький прочный баллон, способный заправлять автоинъекторы, для пополнения которых раньше требовалась система Наномед. Используя чудеса микросхем, он автоматически сортирует нужные химикаты по большинству однореагентных автоинъекторов. При этом он не может заполнить их частично. В верхней части имеется клапан, позволяющий перелить реагенты в другой контейнер или полностью вылить их.
ent-RMCPressurizedCanister = герметичная канистра
    .desc = Герметичный контейнер. Внутренняя часть подсумка канистры сжатых реагентов. Совместим только со своим подсумком, оборудованием или накопительным баком.
ent-RMCPressurizedCanisterBicaridine = { ent-RMCPressurizedCanister }
    .suffix = Бикаридин
    .desc = { ent-RMCPressurizedCanister.desc }
ent-RMCPressurizedCanisterKelotane = { ent-RMCPressurizedCanister }
    .suffix = Келотан
    .desc = { ent-RMCPressurizedCanister.desc }
ent-RMCPressurizedCanisterTricordrazineRevival = { ent-RMCPressurizedCanister }
    .suffix = Трикордразин - Возрождение
    .desc = { ent-RMCPressurizedCanister.desc }
ent-RMCPressurizedCanisterTricordrazine = { ent-RMCPressurizedCanister }
    .suffix = Трикордразин
    .desc = { ent-RMCPressurizedCanister.desc }
ent-RMCVial = ампула
    .desc = Маленькая стеклянная ампула. Вмещает до 30 единиц.
ent-RMCVialTricordrazine = ампула трикордразина
    .desc = Маленькая стеклянная ампула. Вмещает до 30 единиц. Содержит трикордразин, слабодействующий препарат общего назначения для лечения повреждений.
    .suffix = Заполненный, Трикордразин
