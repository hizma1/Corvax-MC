ent-CMFirstAidKit = аптечка первой помощи
    .desc = Это набор для оказания неотложной медицинской помощи при серьёзных травмах. При наличии медицинской подготовки вы сможете уместить её в рюкзаке.
ent-CMFirstAidKitSurgery = базовый набор для полевой хирургии
    .desc = { ent-CMFirstAidKit.desc }
ent-CMFirstAidKitFilled = { ent-CMFirstAidKit }
    .desc = Это набор для оказания неотложной медицинской помощи, содержащий базовые медикаменты и оборудование. Не требует специальной подготовки для использования.
    .suffix = Заполненный
ent-CMFirstAidKitFilledRobust = { ent-CMFirstAidKit }
    .suffix = Заполненный, Робаст
    .desc = { ent-CMFirstAidKit.desc }
ent-CMFirstAidKitSurgeryFilled = { ent-CMFirstAidKitSurgery }
    .desc = Содержит хирургическую нить, прижигатель, скальпель, кровоостанавливающий зажим, ранорасширитель, бинты и инъектор оксикодона для обработки ран.
    .suffix = Заполненный
ent-CMBurnAidKit = аптечка первой помощи при ожогах
    .desc = Это набор для оказания неотложной медицинской помощи на случай, если хранилище боеприпасов десантного корабля решит самопроизвольно загореться.
ent-CMBurnAidKitFilled = { ent-CMBurnAidKit }
    .suffix = Заполненный
    .desc = { ent-CMBurnAidKit.desc }
ent-CMFirstAidO2Kit = аптечка первой помощи при гипоксии
    .desc = Коробка, полная средств для восстановления уровня кислорода в организме.
ent-CMFirstAidO2KitFilled = { ent-CMFirstAidO2Kit }
    .suffix = Заполненный
    .desc = { ent-CMFirstAidO2Kit.desc }
ent-CMAdvFirstAidKit = продвинутая аптечка первой помощи
    .desc = Содержит более эффективные средства лечения, чем базовая аптечка, например, специализированные наборы от ожогов и травм.
ent-CMAdvFirstAidKitFilled = { ent-CMAdvFirstAidKit }
    .suffix = Заполненный
    .desc = { ent-CMAdvFirstAidKit.desc }
ent-CMToxinAidKit = аптечка первой помощи при отравлениях
