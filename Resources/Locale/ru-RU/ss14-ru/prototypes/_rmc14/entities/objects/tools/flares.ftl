ent-RMCFlareC18 = C18 flare
    .desc = A Weston-Yamada-issued flare that burns with a distinct blue shade. Dense text on the label warns of the health risks of breathing burning copper fumes.
    .suffix = PMC
ent-RMCPackFlareC18 = C18 flare pack
