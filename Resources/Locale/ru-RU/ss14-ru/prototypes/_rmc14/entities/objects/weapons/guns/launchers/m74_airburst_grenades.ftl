ent-RMCAirBurstProjectileStarShell = 40-мм граната M74 AGM-S Звездопад
    .desc = { ent-RMCBaseAirBurstProjectile.desc }
ent-RMCAirBurstProjectileSmoke = 40-мм граната M74 AGM-S
