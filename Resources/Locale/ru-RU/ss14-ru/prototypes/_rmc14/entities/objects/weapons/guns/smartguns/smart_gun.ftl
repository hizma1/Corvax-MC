    .desc = { ent-CMMagazineRifleBase.desc }
ent-RMCMagazineSmartGunirradiated = барабанный магазин ML79A облучённые (10x30мм)
    .desc = { ent-CMMagazineRifleBase.desc }
ent-RMCMagazineSmartGunHT = барабанный магазин ML66A голографическое наведение (10x30 мм)
