ent-RMCBaseMeleeWeapon = { "" }
    .desc = { "" }
ent-RMCM5Bayonet = штык-нож M5 «Ночной налётчик»
    .desc = Стандартный штык колониальной морской пехоты. Его можно засунуть в ботинок.
ent-RMCCombatUtilityKnifeA = боевой нож «Дружина»
    .desc = Тяжёлый боевой нож, разработанный для красногвардейцев и диверсионно-разведывательных полков СССП. Очень популярен благодаря своей тяжести и долговечности.
ent-RMCCombatUtilityKnifeB = { ent-RMCCombatUtilityKnifeA }
    .desc = { ent-RMCCombatUtilityKnifeA.desc }
ent-RMCTantoA = боевой нож Mk3
    .desc = В Империи Миртана нож — не просто бесполезная безделушка, которой ты вряд ли воспользуешься в бою. Нож — оружие последнего шанса, символ надежды. Нож есть у каждого человека с ранних лет, его передают по наследству, получают в награду и теряют только с зелёной кровью на нём. Этот выплавлен в форме древнего земного ножа — танто.
ent-RMCTantoB = { ent-RMCTantoA }
    .desc = { ent-RMCTantoA.desc }
ent-RMCSawtoothDaggerA = траншейный нож модели «Фиоре»
    .desc = «Тонкий и хрупко выглядящий нож, больше напоминающий зубочистку» — рассказав это какому-нибудь солдату, он, пожалуй, рассмеялся бы. На самом деле эта «зубочистка» забрала больше душ, чем вы за всю свою солдатскую жизнь и жизни ваших товарищей вместе взятых.
ent-RMCSawtoothDaggerB = { ent-RMCSawtoothDaggerA }
    .desc = { ent-RMCSawtoothDaggerA.desc }
ent-CMM11Knife = метательный нож M11
    .desc = Войсковой нож, предназначенный для метания в противника.
ent-RMCFSKnife = боевой нож Ферберна-Сайкса
    .desc = Легендарный стандартный нож полков штурмовых армий смерти Империи Миртана. Даже в меняющемся ландшафте современной войны вневременной дизайн ножа Ф-С находит применение.
    .suffix = RCM
ent-CMM2132Machete = мачете M2132
    .desc = Новейшее мачете колониальной морской пехоты.
ent-RMCCeremonialSword = церемониальная сабля
    .desc = Изысканная церемониальная сабля, передававшаяся из поколения в поколение. Несмотря на это, за ней очень хорошо ухаживали, и она находится в идеальном состоянии.
ent-RMCM2100Machete = M2100 «Нга́йхи»
    .desc = Более старое мачете ККМП, так себя и не испытавшее. Разработано в Технократии Эранта. Из-за зазубрин его было трудно чистить, и поэтому ККМП отказалась принять его на вооружение, несмотря на превосходную ударную силу.
ent-RMCRoyalMachete = пехотный меч L225
    .desc = L225 — это стандартный пехотный меч пехоты Империи Миртана, имеющий длиннон и тяжелое изогнутое лезвие, повышающее эффективность рубящих ударов.
    .suffix = PVE, Империя
ent-RMCStraightRazor = опасная бритва
    .desc = Любимое оружие коменданта против морских пехотинцев, которые осмеливаются нарушать стандарты ухода за собой.
