ent-RMCBaseTesla = { ent-BaseItem }
    .desc = { ent-BaseItem.desc }
ent-RMCTesla = катушка теслы UE 21S
    .desc = Чудо инженерной мысли производства Nakamura's Engineering, представляющее собой катушку, создающую огромное количество энергии и способную выпускать разряды в сторону врага с помощью оборудованных ИИ датчиков движения с системой опознавания. Оснащена высокомощными термоэлектрическими генераторами.
ent-RMCTeslaMicro = микро-катушка теслы UE 25S
    .desc = Уменьшенная модель UE 25S того же производителя. Обладает менее мощными генераторами, но оснащена улучшенными рассеивателями энергии, благодаря которым катушка способна быстрее перезаряжаться и работать сразу по нескольким целям.
ent-RMCTeslaOverclocked = разогнанная катушка теслы UE 21S
    .desc = Модификация UE 21S, заточенная исключительно на уничтожение. Оснащена крайне мощным генератором на основе взаимодействия Блюспейса и Рэдспейса. Эксклюзивная военная модель.
ent-RMCTeslaTSE = катушка теслы L10D
    .suffix = PVE, RCM IFF
    .desc = { ent-RMCTesla.desc }
