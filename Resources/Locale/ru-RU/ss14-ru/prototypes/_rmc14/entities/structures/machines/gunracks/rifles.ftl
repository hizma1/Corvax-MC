    .desc = { ent-RMCGunRackM54C2Empty.desc }
ent-RMCGunRackType71Empty = оружейная стойка Тип 71
    .desc = Стеллаж для оружия без маркировки бренда. Согласно правилам СССП и Милиции, оружие должно храниться в надежных сейфах и выдаваться только при необходимости. Конечно, большинство подразделений (но не все!) пренебрегают этим правилом и держат стволы в сейфах только на время инспекции.
    .suffix = Тип 71, Пусто
ent-RMCGunRackType71Filled = { ent-RMCGunRackType71Empty }
    .suffix = Тип 71, Заполнено
    .desc = { ent-RMCGunRackType71Empty.desc }
