ent-RMCGunRackM54CEmpty = оружейная стойка M54C
    .desc = Оружейный стеллаж производства AEGIS, предназначенный для хранения длинноствольного оружия. Хотя предполагалось, что первоначальная модель будет легко модифицируемой, ККМП ввела в эксплуатацию стеллажи с фиксированными прорезями, которые подходят только для винтовок M54C. Некоторые говорят, что они были дешевле, другие — что главной причиной была способность морпехов ломать всё, что сложнее вольфрамового шарика.
    .suffix = M54C, Пусто
ent-RMCGunRackM54CFilled = { ent-RMCGunRackM54CEmpty }
    .suffix = M54C, Заполнено
    .desc = { ent-RMCGunRackM54CEmpty.desc }
ent-RMCGunRackM54CMk1Empty = оружейная стойка M54C Mk1
    .desc = Оружейный стеллаж производства AEGIS, предназначенный для хранения длинноствольного оружия. Хотя предполагалось, что первоначальная модель будет легко модифицируемой, ККМП ввела в эксплуатацию стеллажи с фиксированными прорезями, которые подходят только для винтовок M54C Mk1. Некоторые говорят, что они были дешевле, другие — что главной причиной была способность морпехов ломать всё, что сложнее вольфрамового шарика.
    .suffix = M54C Mk1, Пусто
ent-RMCGunRackM54CMk1Filled = { ent-RMCGunRackM54CMk1Empty }
    .suffix = M54C Mk1, Заполнено
    .desc = { ent-RMCGunRackM54CMk1Empty.desc }
ent-RMCGunRackSSG45Empty = оружейная стойка SSG45
    .desc = Оружейный стеллаж производства AEGIS, предназначенный для хранения длинноствольного оружия. Хотя предполагалось, что первоначальная модель будет легко модифицируемой, компания Vitezstvi выпустила стеллажи с фиксированными прорезями, которые подходят только для винтовок SSG45. Кто-то говорит, что они были дешевле, а кто-то — что главной причиной была способность операторов ломать всё, что сложнее вольфрамового шарика.
    .suffix = SSG45, Пусто
ent-RMCGunRackSSG45Filled = { ent-RMCGunRackSSG45Empty }
    .suffix = SSG45, Заполнено
    .desc = { ent-RMCGunRackSSG45Empty.desc }
ent-RMCGunRackType71Empty = оружейная стойка Тип 71
    .desc = Стеллаж для оружия без маркировки какого-либо бренда. Согласно правилам СССП и Милиции, оружие должно храниться в надежных сейфах и выдаваться только при необходимости. Конечно, большинство (но не все!) подразделений пренебрегают этим правилом и держат стволы в сейфах только на время инспекции.
    .suffix = Тип 71, Пусто
ent-RMCGunRackType71Filled = { ent-RMCGunRackType71Empty }
    .suffix = Тип 71, Заполнено
    .desc = { ent-RMCGunRackType71Empty.desc }
