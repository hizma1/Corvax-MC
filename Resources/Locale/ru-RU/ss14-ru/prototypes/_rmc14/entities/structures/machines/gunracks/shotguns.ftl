ent-RMCGunRackM42A2Empty = оружейная стойка M42A2
    .desc = Оружейный стеллаж производства WarTech, предназначенный для хранения длинноствольного оружия. Хотя предполагалось, что первоначальная модель будет легко модифицируемой, ККМП ввела в эксплуатацию стеллажи с фиксированными прорезями, которые подходят только для дробовиков M42A2. Некоторые говорят, что они были дешевле, другие — что главной причиной была способность морпехов ломать всё, что сложнее вольфрамового шарика.
    .suffix = M42A2, Пусто
ent-RMCGunRackM42A2Filled = { ent-RMCGunRackM42A2Empty }
    .suffix = M42A2, Заполнено
    .desc = { ent-RMCGunRackM42A2Empty.desc }
ent-RMCGunRackType23Empty = оружейная стойка Тип 23
    .desc = Стеллаж для оружия без маркировки бренда. Согласно правилам SOF и SPPA, оружие должно храниться в надежных сейфах и выдаваться только при необходимости. Конечно, большинство подразделений (но не все!) пренебрегают этим правилом и держат стволы в сейфах только на время инспекции.
    .suffix = Тип 23, Пусто
ent-RMCGunRackType23Filled = { ent-RMCGunRackType23Empty }
    .suffix = Тип 23, Заполнено
    .desc = { ent-RMCGunRackType23Empty.desc }
