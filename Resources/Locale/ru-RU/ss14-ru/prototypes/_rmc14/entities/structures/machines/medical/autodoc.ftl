ent-RMCAutodoc = медицинская система «Автодок»
    .desc = Устройство для экстренной хирургии, предназначенное для автоматического проведения жизненно важных процедур и базовых операций без участия хирурга.
    .suffix = Спавнится с консолью
ent-RMCAutodocNoConsole = { ent-RMCAutodoc }
    .suffix = Без консоли
    .desc = { ent-RMCAutodoc.desc }
ent-RMCAutodocConsole = консоль управления системой «Автодок»
    .desc = Интерфейс управления, используемый для работы с прилегающим автодоком. Требует специальной подготовки для правильного использования.
ent-RMCAutodocUnskilled = улучшенная медицинская система «Автодок»
    .desc = Гораздо более дорогая модель автодока, оснащённая диагностическим модулем с ИИ. В результате получился гораздо более простой интерфейс, которым может пользоваться любой человек, независимо от подготовки.
    .suffix = Без навыков, Улучшенная
ent-RMCAutodocConsoleUpgraded = улучшенная консоль управления автодоком
    .desc = { ent-RMCAutodocConsole.desc }
