ent-RMCSleeper = медкапсула
    .desc = Высокотехнологичная кровать со встроенными инъекторами, аппаратом для диализа и базовым сканером здоровья.
    .suffix = Спавнится с консолью
ent-RMCSleeperNoConsole = { ent-RMCSleeper }
    .suffix = Без консоли
    .desc = { ent-RMCSleeper.desc }
ent-RMCSleeperConsole = консоль медкапсулы
    .desc = Консоль для управления медкапсулой. Позволяет вводить химикаты и проводить диализ.
ent-RMCSleeperAdvanced = улучшенная медкапсула
    .desc = Более дорогая модель медкапсулы, оснащённая дополнительными наборами химикатов и продвинутым аппаратом для диализа, способным удалять большее количество веществ одновременно и гораздо быстрее.
    .suffix = Улучшенная консоль
ent-RMCSleeperConsoleUpgraded = улучшенная консоль медкапсулы
    .desc = { ent-RMCSleeperConsole.desc }
