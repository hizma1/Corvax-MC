ent-CMSandbagEmpty = пустые мешки
    .desc = Несколько пустых мешков, если вы хотите их использовать, лучше их наполнить.
ent-CMSandbagEmpty50 = { ent-CMSandbagEmpty }
    .suffix = 50
    .desc = { ent-CMSandbagEmpty.desc }
ent-CMSandbagEmpty25 = { ent-CMSandbagEmpty }
    .suffix = 25
    .desc = { ent-CMSandbagEmpty.desc }
ent-CMSandbagFull = мешки с песком
    .desc = Несколько мешков, наполненных песком. Пока просто обуза, но скоро будут использованы в качестве укреплений.
ent-CMSandbagFull50 = { ent-CMSandbagFull }
    .suffix = 50
    .desc = { ent-CMSandbagFull.desc }
ent-CMSandbagFull25 = { ent-CMSandbagFull }
    .suffix = 25
    .desc = { ent-CMSandbagFull.desc }
ent-RMCBarricadeSandbagSoro = { ent-CMBarricadeSandbag }
    .suffix = Brown
    .desc = { ent-CMBarricadeSandbag.desc }
